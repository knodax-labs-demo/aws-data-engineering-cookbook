{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRedshiftGetBucketAcl",
      "Effect": "Allow",
      "Principal": {
        "Service": "redshift.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::$REDSHIFT_LOG_BUCKET"
    },
    {
      "Sid": "AllowRedshiftWriteLogs",
      "Effect": "Allow",
      "Principal": {
        "Service": "redshift.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::$REDSHIFT_LOG_BUCKET/audit-logs/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control"
        }
      }
    }
  ]
}
