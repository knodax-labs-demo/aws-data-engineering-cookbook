{
  "Name": "$TABLE_NAME",
  "StorageDescriptor": {
    "Columns": [
      {
        "Name": "customer_id",
        "Type": "int"
      },
      {
        "Name": "customer_name",
        "Type": "string"
      },
      {
        "Name": "region",
        "Type": "string"
      },
      {
        "Name": "sales_amount",
        "Type": "int"
      }
    ],
    "Location": "s3://$RAW_BUCKET/sales/",
    "InputFormat": "org.apache.hadoop.mapred.TextInputFormat",
    "OutputFormat": "org.apache.hadoop.hive.ql.io.HiveIgnoreKeyTextOutputFormat",
    "SerdeInfo": {
      "SerializationLibrary": "org.apache.hadoop.hive.serde2.lazy.LazySimpleSerDe",
      "Parameters": {
        "field.delim": ",",
        "skip.header.line.count": "1"
      }
    }
  },
  "PartitionKeys": [
    {
      "Name": "year",
      "Type": "string"
    },
    {
      "Name": "month",
      "Type": "string"
    }
  ],
  "TableType": "EXTERNAL_TABLE"
}
