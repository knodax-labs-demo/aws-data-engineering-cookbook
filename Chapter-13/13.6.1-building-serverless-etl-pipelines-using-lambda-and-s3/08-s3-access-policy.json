{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadRawDataObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::$RAW_BUCKET/*"
    },
    {
      "Sid": "WriteCuratedDataObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::$CURATED_BUCKET/*"
    }
  ]
}
