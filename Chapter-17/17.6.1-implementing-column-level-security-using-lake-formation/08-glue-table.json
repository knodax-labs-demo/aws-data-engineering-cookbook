      },
      {
        "Name": "department",
        "Type": "string"
      },
      {
        "Name": "salary",
        "Type": "int"
      },
      {
        "Name": "ssn",
        "Type": "string"
      }
    ],
    "Location": "s3://$DATA_BUCKET/",
