{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadDynamoDBStreams",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetRecords",
        "dynamodb:GetShardIterator",
        "dynamodb:DescribeStream",
        "dynamodb:ListStreams"
      ],
      "Resource": "$STREAM_ARN"
    },
    {
      "Sid": "WriteCDCObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::$CDC_BUCKET/*"
    }
  ]
}
